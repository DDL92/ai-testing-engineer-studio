{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "playwright.config.ts",
    "playwright-framework/**/*.ts",
    "apps/**/*.ts",
    "src/**/*.ts"
  ]
}
